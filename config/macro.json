        { "site": "cnbc.com", "query": "markets" },
        { "site": "ft.com", "query": "markets" },
        { "site": "marketwatch.com", "query": "markets" },
        { "site": "finance.yahoo.com", "query": "markets" }
      ]
    },
    "L2_paywalled_headlines": {
      "description": "유료 매체 — 헤드라인 + 요약만 인용 가능",
